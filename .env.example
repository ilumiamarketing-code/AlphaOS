# Fuentes gratuitas/demo por defecto — deja vacío para usar mocks/yfinance.
ALPHA_VANTAGE_API_KEY=
POLYGON_API_KEY=
NEWSAPI_API_KEY=
FRED_API_KEY=
# Pendiente de conectar: historial de transacciones ETH para wallet flow
# (blockchain_info_adapter.py solo cubre Bitcoin). Cuenta gratis en
# etherscan.io/register.
ETHERSCAN_API_KEY=

# Opcional: sube el límite de GitHub de 60 a 5000 req/hora. Token de
# lectura pública en github.com/settings/tokens (sin permisos especiales).
GITHUB_TOKEN=

# App gratuita tipo "script" en reddit.com/prefs/apps.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Registro gratis en coinmarketcal.com/en/api (unlocks, forks, eventos
# regulatorios). Snapshot (gobernanza DAO) no necesita key.
COINMARKETCAL_API_KEY=

# Umbral mínimo de convicción (0-100) para que el engine emita una señal.
# 45 = punto intermedio (ver config.py para el detalle del cálculo).
SIGNAL_CONFIDENCE_THRESHOLD=45
